// Copy this file to Config/Secrets.xcconfig and fill in local values.
// Config/Secrets.xcconfig is ignored by git.

STRAVA_CLIENT_ID =
STRAVA_REDIRECT_URI = mangox:/$()/localhost/strava-auth

WHOOP_CLIENT_ID =
WHOOP_REDIRECT_URI = mangox:/$()/localhost/whoop-auth
// WHOOP_CLIENT_SECRET — set in Supabase project secrets (see Docs/SUPABASE_SETUP.md), not here.

USER_DATA_KEY =
MANGOX_COACH_STAFF_TIER =

// Facebook / Meta App ID (required for Instagram Stories sharing via source_application param).
// This is a public value, not a secret. Put the real ID here in local Secrets.xcconfig if overriding.
FACEBOOK_APP_ID =

// Supabase. URL host without scheme so xcconfig doesn't choke on `//`.
SUPABASE_URL_HOST = jvhkplgacbeuksiphgyk.supabase.co
SUPABASE_PUBLISHABLE_KEY =

USER_DATA_KEY = 